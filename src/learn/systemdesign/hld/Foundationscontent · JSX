                  padding: "8px 16px", background: "rgba(59,130,246,0.1)", border: "1px solid rgba(59,130,246,0.25)",
                  borderRadius: "8px", color: "#93c5fd", fontSize: "0.82rem", fontWeight: 700,
                  textDecoration: "none", fontFamily: "'Syne', sans-serif", letterSpacing: "0.02em"
                }}>{l.label} ↗</a>
              ))}
            </div>
          </div>

        </main>
      </div>
    </>
